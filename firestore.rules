rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function getUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isSuperAdmin() {
      return request.auth != null && getUser().role == 'superadmin';
    }
    function isAdminOrAbove() {
      return request.auth != null && 
             (getUser().role == 'admin' || getUser().role == 'superadmin');
    }
    function isActiveUser() {
      return request.auth != null && 
             getUser().status == 'active';
    }

    // Users collection
    match /users/{userId} {
      // Anyone authenticated can read their own doc (needed at login)
      allow read: if request.auth != null && request.auth.uid == userId;
      // Active admins/superadmins can read all user docs
      allow read: if isAdminOrAbove() && isActiveUser();
      // Only superadmin can write user docs (approve, suspend, promote etc.)
      allow write: if isSuperAdmin() && isActiveUser();
      // New registrations: user can create their OWN doc
      allow create: if request.auth != null && request.auth.uid == userId;
    }

    // Everything else
    match /{document=**} {
      allow read: if isActiveUser();
      allow write: if isAdminOrAbove() && isActiveUser();
    }
  }
}

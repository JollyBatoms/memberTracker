rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function getUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isSuperAdmin() {
      return request.auth != null && getUser().role == 'superadmin';
    }
    function isAdminOrAbove() {
      return request.auth != null &&
             (getUser().role == 'admin' || getUser().role == 'superadmin');
    }
    function isActiveUser() {
      return request.auth != null && getUser().status == 'active';
    }

    // Users collection
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdminOrAbove() && isActiveUser();
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if isSuperAdmin() && isActiveUser();
    }

    // Hub posts — everyone active can read published posts
    match /hub_posts/{postId} {
      allow read: if isActiveUser();
      allow create: if isActiveUser();
      allow update: if isAdminOrAbove() && isActiveUser();
      allow delete: if isAdminOrAbove() && isActiveUser();

      // Comments — everyone active can read and write
      match /comments/{commentId} {
        allow read: if isActiveUser();
        allow create: if isActiveUser();
        allow delete: if isAdminOrAbove() && isActiveUser();
      }
    }

    // Notifications — users can read their own
    match /notifications/{notifId} {
      allow read, update, delete: if request.auth != null &&
        resource.data.toUserId == request.auth.uid;
      allow create: if isActiveUser();
    }

    // Everything else
    match /{document=**} {
      allow read: if isActiveUser();
      allow write: if isAdminOrAbove() && isActiveUser();
    }
  }
}

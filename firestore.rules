rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read only their own document
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    // Helper: look up the caller's role from their user document
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function getStatus() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status;
    }

    function isActive() {
      return request.auth != null && getStatus() == 'active';
    }

    function isAdmin() {
      return isActive() && (getRole() == 'admin' || getRole() == 'superadmin');
    }

    function isSuperAdmin() {
      return isActive() && getRole() == 'superadmin';
    }

    function isMember() {
      return isActive() && getRole() == 'member';
    }

    // Notifications — users read only their own
    match /notifications/{notifId} {
      allow read: if request.auth != null &&
                     resource.data.toUserId == request.auth.uid;
      allow write: if isAdmin();
    }

    // User management — only Super Admin can write user docs
    match /users/{userId} {
      allow read:  if isAdmin() ||
                      (request.auth != null && request.auth.uid == userId);
      allow write: if isSuperAdmin();
    }

    // Members, attendance, events, finance — admins write, all active users read
    match /{collection}/{document=**} {
      allow read:  if isAdmin() || isMember();
      allow write: if isAdmin();
    }
  }
}

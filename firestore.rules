rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function myRole() {
      return isSignedIn() ? userDoc().role : '';
    }

    function isSuperAdmin() {
      return myRole() == 'superadmin';
    }

    function isAdmin() {
      return myRole() == 'admin';
    }

    function isPrivileged() {
      return myRole() == 'admin' || myRole() == 'superadmin';
    }

    function isAnyMember() {
      return myRole() == 'member' || myRole() == 'admin' || myRole() == 'superadmin';
    }

    // Users
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSuperAdmin() || request.auth.uid == uid;
      allow delete: if isSuperAdmin();
    }

    // Members
    match /members/{id} {
      allow read: if isAnyMember();
      allow write: if isPrivileged();
    }

    // Past members
    match /past_members/{id} {
      allow read: if isAnyMember();
      allow write: if isPrivileged();
    }

    // Attendance
    match /attendance/{id} {
      allow read: if isAnyMember();
      allow write: if isPrivileged();
    }

    // Events
    match /events/{id} {
      allow read: if isAnyMember();
      allow write: if isPrivileged();
    }

    // Positions
    match /positions/{id} {
      allow read: if isAnyMember();
      allow write: if isPrivileged();
    }

    // Settings / Memo
    match /settings/{id} {
      allow read: if isAnyMember();
      allow write: if isPrivileged();
    }

    // Finance
    match /finance_records/{id} {
      allow read: if isPrivileged();
      allow write: if isPrivileged();
    }
    match /finance_transfers/{id} {
      allow read: if isPrivileged();
      allow write: if isPrivileged();
    }
    match /finance_levies/{id} {
      allow read: if isPrivileged();
      allow write: if isPrivileged();
    }

    // Notifications
    match /notifications/{id} {
      allow read: if isSignedIn() && (
        resource.data.toUserId == request.auth.uid || isSuperAdmin()
      );
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.toUserId == request.auth.uid;
    }

    // Audit logs
    match /audit_logs/{id} {
      allow read: if isSuperAdmin();
      allow create: if isAnyMember();
      allow update, delete: if false;
    }

    // Fellowship Hub
    match /hub_posts/{id} {
      allow read: if isAnyMember();
      allow create: if isAnyMember();
      allow update: if isPrivileged() || request.auth.uid == resource.data.authorId;
      allow delete: if isPrivileged() || request.auth.uid == resource.data.authorId;
    }
    match /hub_posts/{postId}/comments/{commentId} {
      allow read: if isAnyMember();
      allow create: if isAnyMember();
      allow delete: if isPrivileged() || request.auth.uid == resource.data.authorId;
    }
  }
}
